<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UEA Universiapolis | L'avenir en confiance</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Palette basée sur le logo */
        :root { 
            --uea-pink: #fbcfe8;
            --uea-pink-dark: #f472b6;
            --uea-gradient: linear-gradient(135deg, #fef3c7 0%, #fbcfe8 50%, #f472b6 100%);
            --uea-black: #000000;
        }
        
        body { background-color: #ffffff; min-height: 100vh; display: flex; flex-direction: column; font-family: 'Segoe UI', sans-serif; color: var(--uea-black); }
        
        /* Style Premium */
        .bg-uea-gradient { background: var(--uea-gradient); }
        .text-uea-pink { color: var(--uea-pink-dark); }
        .border-uea-pink { border-color: var(--uea-pink-dark); }
        
        /* Navigation */
        .nav-active { border-bottom: 3px solid var(--uea-pink-dark); color: var(--uea-pink-dark) !important; }
        
        /* Cartes d'activités avec effet Glassmorphism */
        .activity-card { 
            transition: 0.4s; 
            border-radius: 30px; 
            overflow: hidden; 
            border: 2px solid transparent;
            background: white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }
        .activity-card:hover { 
            transform: translateY(-12px); 
            border-color: var(--uea-pink-dark);
            box-shadow: 0 20px 30px rgba(244, 114, 182, 0.2);
        }

        /* Système de détails (Modal) */
        #detail-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); z-index: 2000; overflow-y: auto; padding: 20px;
            backdrop-filter: blur(10px);
        }
        .detail-window { 
            max-width: 900px; margin: 20px auto; background: white; border-radius: 40px; overflow: hidden;
            border: 5px solid white; box-shadow: 0 0 50px rgba(244, 114, 182, 0.4);
        }

        .btn-return {
            background: var(--uea-black); color: white; padding: 12px 30px; border-radius: 100px;
            font-weight: 900; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s;
        }
        .btn-return:hover { background: var(--uea-pink-dark); transform: scale(1.05); }
    </style>
</head>
<body>

    <nav class="bg-black text-white sticky top-0 z-50 shadow-2xl">
        <div class="max-w-7xl mx-auto px-4 flex justify-between items-center h-20">
            <div class="flex items-center space-x-4 cursor-pointer" onclick="navigate('accueil')">
                <img src="1000537935.png" alt="Logo UEA" class="w-14 h-14 object-contain rounded-full border-2 border-white bg-white">
                <div>
                    <span class="font-black text-2xl block tracking-tighter italic">UEA</span>
                    <span class="text-[10px] text-pink-300 font-bold tracking-[0.2em] uppercase">L'avenir en confiance</span>
                </div>
            </div>
            <div class="hidden md:flex space-x-8 font-black uppercase text-xs tracking-widest">
                <button onclick="navigate('accueil')" id="nav-accueil" class="hover:text-pink-400">Accueil</button>
                <button onclick="navigate('bureau')" id="nav-bureau" class="hover:text-pink-400">Le Bureau</button>
                <button onclick="navigate('activites')" id="nav-activites" class="hover:text-pink-400">Événements</button>
                <button onclick="navigate('about')" id="nav-about" class="hover:text-pink-400">Contact</button>
            </div>
        </div>
    </nav>

    <div id="detail-overlay">
        <div class="detail-window">
            <div class="relative">
                <img id="detail-img" src="" class="w-full h-auto object-cover max-h-[600px]">
                <div class="absolute top-6 left-6">
                    <button class="btn-return shadow-2xl" onclick="closeDetails()">
                        <i class="fas fa-arrow-left mr-2"></i> Retour
                    </button>
                </div>
            </div>
            <div class="p-10 bg-white">
                <h2 id="detail-title" class="text-5xl font-black mb-4 uppercase italic"></h2>
                <div class="h-1 w-24 bg-pink-400 mb-6"></div>
                <p id="detail-desc" class="text-gray-600 text-xl leading-relaxed"></p>
            </div>
        </div>
    </div>

    <main id="content-area" class="flex-grow"></main>

    <footer class="bg-black text-white py-16 text-center border-t-8 border-pink-200">
        <div class="flex justify-center space-x-12 mb-8">
            <a href="https://www.instagram.com/ueauniversiapolis" class="text-4xl hover:text-pink-400 transition"><i class="fab fa-instagram"></i></a>
            <a href="https://wa.me/212781688850" class="text-4xl hover:text-green-400 transition"><i class="fab fa-whatsapp"></i></a>
        </div>
        <img src="1000537935.png" class="w-20 mx-auto mb-6 opacity-50">
        <p class="text-xs text-gray-500 font-bold tracking-[0.5em] uppercase">&copy; 2026 UEA Universiapolis Agadir</p>
    </footer>

    <script>
        // DONNÉES RÉELLES AVEC TES IMAGES
        const activitiesData = {
            halloween: { 
                title: "Halloween Movie Night", 
                img: "1000959451.jpg", 
                desc: "Une immersion totale dans l'horreur. Notre Movie Night a rassemblé la communauté pour une soirée de frissons, de popcorn et de cohésion." 
            },
            star_game: { 
                title: "All Star Game", 
                img: "1000959452.jpg", 
                desc: "Le tournoi sportif le plus attendu. Un moment de compétition intense et de fraternité entre toutes les filières d'Universiapolis." 
            }
        };

        const pages = {
            accueil: `
                <section class="py-24 px-6 text-center bg-uea-gradient">
                    <img src="1000537935.png" class="w-48 h-48 mx-auto mb-8 drop-shadow-2xl">
                    <h1 class="text-7xl font-black mb-6 uppercase tracking-tighter italic">L'Avenir en <br><span class="text-white drop-shadow-lg">Confiance</span></h1>
                    <p class="text-xl max-w-2xl mx-auto font-bold text-gray-800">Bienvenue sur le portail officiel de l'Union des Étudiants Africains.</p>
                    <button onclick="navigate('activites')" class="mt-12 bg-black text-white px-12 py-5 rounded-full font-black uppercase text-sm tracking-widest hover:scale-110 transition shadow-2xl">Voir nos succès</button>
                </section>`,

            activites: `
                <section class="py-20 px-6 max-w-7xl mx-auto">
                    <h2 class="text-6xl font-black mb-20 text-center uppercase italic underline decoration-pink-400 decoration-8 underline-offset-8">Nos Activités</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
                        <div class="activity-card" onclick="openDetails('halloween')">
                            <div class="relative">
                                <img src="1000959451.jpg" class="w-full h-[500px] object-cover">
                                <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent opacity-60"></div>
                                <div class="absolute bottom-8 left-8 text-white text-3xl font-black uppercase tracking-tighter">Halloween Party</div>
                            </div>
                        </div>
                        <div class="activity-card" onclick="openDetails('star_game')">
                            <div class="relative">
                                <img src="1000959452.jpg" class="w-full h-[500px] object-cover">
                                <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent opacity-60"></div>
                                <div class="absolute bottom-8 left-8 text-white text-3xl font-black uppercase tracking-tighter">All Star Game</div>
                            </div>
                        </div>
                    </div>
                </section>`,

            bureau: `<div class="p-20 text-center"><h2 class="text-4xl font-black">LE BUREAU EXÉCUTIF</h2><p class="mt-4">Section en cours de chargement avec vos données membres...</p></div>`,
            
            about: `<div class="p-20 text-center bg-gray-50"><h2 class="text-4xl font-black">CONTACTEZ-NOUS</h2><p class="mt-4 text-pink-500 font-bold">Email: ueauniversiapolis@gmail.com</p></div>`
        };

        function navigate(pageId) {
            document.getElementById('content-area').innerHTML = pages[pageId];
            window.scrollTo(0,0);
            // Gestion du style actif
            document.querySelectorAll('nav button').forEach(b => b.classList.remove('nav-active'));
            if(document.getElementById('nav-'+pageId)) document.getElementById('nav-'+pageId).classList.add('nav-active');
        }

        function openDetails(id) {
            const data = activitiesData[id];
            document.getElementById('detail-img').src = data.img;
            document.getElementById('detail-title').innerText = data.title;
            document.getElementById('detail-desc').innerText = data.desc;
            document.getElementById('detail-overlay').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeDetails() {
            document.getElementById('detail-overlay').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        window.onload = () => navigate('accueil');
    </script>
</body>
</html>
